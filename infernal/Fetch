    green)   COLOR='\x1b[32m' ;;
    blue)    COLOR='\x1b[34m' ;;
    red)     COLOR='\x1b[31m' ;;
    cyan)    COLOR='\x1b[36m' ;;
    magenta) COLOR='\x1b[35m' ;;
    yellow)  COLOR='\x1b[33m' ;;
    white)   COLOR='\x1b[37m' ;;
    *)       COLOR='\x1b[32m' ;;
esac
